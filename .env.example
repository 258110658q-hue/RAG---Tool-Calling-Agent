# ============================================================
# 环境变量模板文件
# 使用方法：
#   1. 复制此文件，重命名为 .env
#   2. 填入你自己的真实配置值
#   3. .env 文件不会被提交到 Git（已在 .gitignore 中排除）
# ============================================================

# 大模型 API 密钥（必填）
# 如果你使用 OpenAI 官方：在 https://platform.openai.com/api-keys 获取
# 如果你使用国内中转代理：填写代理服务商提供的 Key
LLM_API_KEY=sk-your-api-key-here

# API 服务地址（可选，默认使用 OpenAI 官方地址）
# OpenAI 官方：https://api.openai.com/v1
# 国内代理示例：https://api.your-proxy.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# 默认模型名称（可选）
LLM_MODEL=gpt-4o

# Embedding 模型名称（用于文本向量化）
# OpenAI：text-embedding-3-small（1536维，推荐）或 text-embedding-ada-002
# 如果你的供应商不提供 Embedding 服务，可以设置 EMBEDDING_BASE_URL 指向另一个端点
EMBEDDING_MODEL=text-embedding-3-small

# Embedding API 地址（可选，默认为空则复用 LLM_BASE_URL）
# EMBEDDING_BASE_URL=
