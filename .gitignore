# ============================================================
# Git 忽略规则
# 这些文件/文件夹不会被提交到版本管理系统
# ============================================================

# 虚拟环境 —— 体积大，每个开发者自己创建
venv/

# 环境变量 —— 包含敏感的 API Key，绝对不能提交
.env

# Python 缓存文件 —— 解释器自动生成，无意义
__pycache__/
*.pyc
*.pyo

# IDE 配置文件 —— 每个人的编辑器设置不同
.vscode/
.idea/

# 系统文件
.DS_Store
Thumbs.db

# 数据文件夹中的运行时生成数据（不入库）
data/chroma_db/
data/eval_results.json
data/prompt_comparison.json
